@{
    ViewBag.Title = "Phân quyền nhân viên";
}

@model SV22T1020438.Admin.Models.EmployeeRoleViewModel

@section PageToolBar {
    <button type="submit" form="formChangeRole" class="btn btn-primary">
        <i class="bi bi-shield-check me-1"></i>
        Lưu phân quyền
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-check me-2"></i>
                    Phân quyền cho nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formChangeRole" method="post" action="~/Employee/ChangeRole/@Model.Employee.EmployeeID">

                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-person me-1"></i>
                            Thông tin nhân viên
                        </legend>

                        <dl class="row mb-0">
                            <dt class="col-sm-3">Họ và tên</dt>
                            <dd class="col-sm-9">@Model.Employee.FullName</dd>

                            <dt class="col-sm-3">Email</dt>
                            <dd class="col-sm-9">@Model.Employee.Email</dd>

                            <dt class="col-sm-3">Trạng thái</dt>
                            <dd class="col-sm-9">
                                @if (Model.Employee.IsWorking)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã nghỉ việc</span>
                                }
                            </dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-shield-lock me-1"></i>
                            Danh sách quyền
                        </legend>

                        <div class="table-responsive">
                            <table class="table table-bordered table-hover align-middle">
                                <thead class="table-secondary">
                                    <tr>
                                        <th style="width:60px;" class="text-center">Chọn</th>
                                        <th>Tên quyền</th>
                                        <th>Mô tả quyền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="text-center">
                                            <input class="form-check-input" type="checkbox" name="SelectedRoles" value="admin"
                                                   @(Model.SelectedRoles.Any(r => string.Equals(r, "admin", StringComparison.OrdinalIgnoreCase)) ? "checked" : "") />
                                        </td>
                                        <td>Administrator</td>
                                        <td>Quyền quản trị hệ thống</td>
                                    </tr>
                                    <tr>
                                        <td class="text-center">
                                            <input class="form-check-input" type="checkbox" name="SelectedRoles" value="datamanager"
                                                   @(Model.SelectedRoles.Any(r => string.Equals(r, "datamanager", StringComparison.OrdinalIgnoreCase)) ? "checked" : "") />
                                        </td>
                                        <td>Data manager</td>
                                        <td>Quyền quản lý dữ liệu</td>
                                    </tr>
                                    <tr>
                                        <td class="text-center">
                                            <input class="form-check-input" type="checkbox" name="SelectedRoles" value="sales"
                                                   @(Model.SelectedRoles.Any(r => string.Equals(r, "sales", StringComparison.OrdinalIgnoreCase)) ? "checked" : "") />
                                        </td>
                                        <td>Sales</td>
                                        <td>Quyền xử lý nghiệp vụ bán hàng</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </fieldset>

                </form>
            </div>
        </div>
    </div>
</div>
