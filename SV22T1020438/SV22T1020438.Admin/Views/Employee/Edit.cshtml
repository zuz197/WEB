@model Employee
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        @Html.ValidationMessage("Error", new { @class = "text-danger" })
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-person-badge me-2"></i>
                    Thông tin nhân viên
                </h5>
            </div>

            <div class="card-body">
                <!-- 🔥 enctype QUAN TRỌNG -->
                <form id="formEdit" method="post" action="~/Employee/SaveData" enctype="multipart/form-data">
                    
                    <input type="hidden" asp-for="EmployeeID" />

                    <!-- 🔥 FIX: giữ ảnh cũ -->
                    <input type="hidden" name="Photo" value="@Model.Photo" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Họ và tên</label>
                        <div class="col-sm-5">
                            <input type="text" asp-for="FullName"
                                   class="form-control"
                                   placeholder="Nhập họ và tên" autofocus />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                        <label class="col-sm-2 col-form-label text-end">Ngày sinh</label>
                        <div class="col-sm-2">
                            <input type="date" asp-for="BirthDate"
                                   class="form-control" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Địa chỉ</label>
                        <div class="col-sm-9">
                            <textarea class="form-control" asp-for="Address"
                                      rows="3"
                                      placeholder="Nhập địa chỉ"></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Điện thoại</label>
                        <div class="col-sm-2">
                            <input type="tel" asp-for="Phone"
                                   class="form-control"
                                   placeholder="Nhập số điện thoại" />
                        </div>
                        <label class="col-sm-1 col-form-label text-end">Email</label>
                        <div class="col-sm-6">
                            <input type="email" asp-for="Email"
                                   class="form-control"
                                   placeholder="Nhập email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- 🔥 Upload ảnh -->
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <input type="file"
                                   name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="previewImage(this)" />

                            <div class="mt-2">
                                <img id="imgPreview"
                                     src="~/images/employees/@(string.IsNullOrWhiteSpace(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                     class="img-thumbnail"
                                     style="max-height: 150px;" />
                            </div>
                        </div>
                    </div>

                    <!-- 🔥 FIX checkbox -->
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            
                            <!-- hidden để tránh mất dữ liệu -->
                            <input type="hidden" name="IsWorking" value="false" />

                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="IsWorking"
                                       value="true"
                                       @(Model.IsWorking ? "checked" : "") />
                                <label class="form-check-label">
                                    Đang làm việc
                                </label>
                            </div>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function previewImage(input) {
        const img = document.getElementById("imgPreview");
        if (input.files && input.files[0]) {
            img.src = URL.createObjectURL(input.files[0]);
        }
    }
</script>