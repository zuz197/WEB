<nav class="app-header navbar navbar-expand bg-body-secondary">
    <div class="container-fluid">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                    <i class="bi bi-list"></i>
                </a>
            </li>
            <li class="nav-item d-none d-md-block">
                <a href="~/" class="nav-link">Trang chủ</a>
            </li>            
        </ul>        

        <ul class="navbar-nav ms-auto">  
            @{
                var userData = User.GetUserData();

                // ✅ FIX đường dẫn ảnh
                var photoPath = string.IsNullOrEmpty(userData?.Photo)
                    ? "/images/no-image.png"
                    : "/images/employees/" + userData.Photo;
            }

            <li class="nav-item dropdown user-menu">
                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                    <img src="@photoPath"
                         class="user-image rounded-circle shadow"
                         style="width:40px;height:40px;object-fit:cover;"
                         alt="User Image" />
                    <span class="d-none d-md-inline">@userData?.DisplayName</span>
                </a>

                <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end">                    
                    <li class="user-header text-bg-primary">
                        <img src="@photoPath"
                             class="rounded-circle shadow"
                             style="width:90px;height:90px;object-fit:cover;"
                             alt="User Image" />
                        <p>
                            @userData?.DisplayName
                        </p>
                    </li>                    

                    <li class="user-footer">
                        <a href="~/Account/ChangePassword" class="btn btn-default btn-flat">
                            Đổi mật khẩu
                        </a>
                        <a href="~/Account/Logout" class="btn btn-default btn-flat float-end">
                            Thoát
                        </a>
                    </li>                    
                </ul>
            </li>            
        </ul>        
    </div>
</nav>