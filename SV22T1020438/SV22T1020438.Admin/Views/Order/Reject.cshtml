@model int
@{
    Layout = null;
}
<form asp-controller="Order" asp-action="RejectConfirm" asp-route-id="@Model" method="post">
    @Html.AntiForgeryToken()
    <div class="modal-header text-bg-danger">
        <strong class="modal-title">Xác nhận từ chối đơn hàng</strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="alert alert-danger d-flex align-items-center mb-0">
            <i class="bi bi-info-circle me-2"></i>
            Bạn có thực sự muốn từ chối đơn hàng này hay không?
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-check"></i> Từ chối đơn
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>
