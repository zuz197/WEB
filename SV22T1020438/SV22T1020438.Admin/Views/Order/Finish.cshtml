@model int
@{
    Layout = null;
}
<form asp-controller="Order" asp-action="FinishConfirm" asp-route-id="@Model" method="post">
    @Html.AntiForgeryToken()
    <div class="modal-header text-bg-success">
        <strong class="modal-title">Xác nhận đơn hàng thành công</strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="alert alert-success d-flex align-items-center mb-0">
            <i class="bi bi-info-circle me-2"></i>
            Bạn có chắc chắn hoàn tất đơn này? (Áp dụng cho đơn đang giao hoặc đơn không cần ship)
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-success">
            <i class="bi bi-check"></i> Hoàn tất
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>
