@model int
@{
    Layout = null;
}
<form asp-controller="Order" asp-action="RecallFromShippingConfirm" asp-route-id="@Model" method="post">
    @Html.AntiForgeryToken()
    <div class="modal-header text-bg-info">
        <strong class="modal-title">Thu hồi — giao lại</strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="alert alert-info mb-0">
            <i class="bi bi-info-circle me-2"></i>
            Đơn sẽ trở lại trạng thái <strong>Đã duyệt</strong>, bỏ người giao hiện tại để bạn <strong>chọn shipper khác</strong> (shipper cũ không đến được, cần đổi ca, v.v.).
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-arrow-counterclockwise"></i> Thu hồi và giao lại
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>
