@model SV22T1020438.Models.Sales.SalesDashboardData
@using System.Globalization
@using System.Text.Json
@{
    var vn = CultureInfo.GetCultureInfo("vi-VN");
    var labelsJson = JsonSerializer.Serialize(Model.MonthlyChartLabels);
    var valuesJson = JsonSerializer.Serialize(Model.MonthlyChartValues);
}

<div class="row">
    <div class="col-lg-3 col-6">
        <div class="card text-bg-primary">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Doanh thu hoàn tất hôm nay</h6>
                        <h3 class="mb-0">@Model.TodayRevenue.ToString("N0", vn) đ</h3>
                    </div>
                    <i class="bi bi-currency-dollar fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-success">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Tổng số đơn hàng</h6>
                        <h3 class="mb-0">@Model.TotalOrderCount.ToString("N0", vn)</h3>
                    </div>
                    <i class="bi bi-receipt fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-warning">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Khách hàng</h6>
                        <h3 class="mb-0">@Model.CustomerCount.ToString("N0", vn)</h3>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-danger">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Mặt hàng</h6>
                        <h3 class="mb-0">@Model.ProductCount.ToString("N0", vn)</h3>
                    </div>
                    <i class="bi bi-box-seam fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-lg-8">
        <div class="card card-success card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-bar-chart me-1"></i>
                    Doanh thu theo tháng (6 tháng gần nhất)
                </h5>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" height="150"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card card-info card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-star me-1"></i>
                    Top mặt hàng (đơn đã hoàn tất)
                </h5>
            </div>
            <div class="card-body p-0">
                @if (Model.TopProducts.Count == 0)
                {
                    <p class="text-muted text-center py-4 mb-0">Chưa có dữ liệu bán hàng</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var row in Model.TopProducts)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                <span class="text-truncate me-2" title="@row.ProductName">@row.ProductName</span>
                                <span class="badge bg-success">@row.TotalQuantity.ToString("N0", vn)</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-clock-history me-1"></i>
                    Đơn hàng cần xử lý (chờ duyệt / đã duyệt / đang giao)
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mã đơn</th>
                                <th>Khách hàng</th>
                                <th>Ngày</th>
                                <th class="text-end">Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th class="text-center" style="width:1%"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.PendingOrders.Count == 0)
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">Không có đơn cần xử lý</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var o in Model.PendingOrders)
                                {
                                    <tr>
                                        <td>#@o.OrderID</td>
                                        <td>@o.CustomerName</td>
                                        <td>@o.OrderTime.ToString("dd/MM/yyyy")</td>
                                        <td class="text-end">@o.SumOfPrice.ToString("N0", vn)</td>
                                        <td>
                                            @if (o.Status == SV22T1020438.Models.Sales.OrderStatusEnum.New)
                                            {
                                                <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                            }
                                            else if (o.Status == SV22T1020438.Models.Sales.OrderStatusEnum.Accepted)
                                            {
                                                <span class="badge bg-primary">Đã duyệt</span>
                                            }
                                            else if (o.Status == SV22T1020438.Models.Sales.OrderStatusEnum.Shipping)
                                            {
                                                <span class="badge bg-info text-dark">Đang giao</span>
                                            }
                                        </td>
                                        <td class="text-center text-nowrap">
                                            <a href="~/Order/Detail/@o.OrderID" class="btn btn-sm btn-primary">
                                                <i class="bi bi-receipt"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('revenueChart');
        const chartLabels = @Html.Raw(labelsJson);
        const chartValues = @Html.Raw(valuesJson);

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: chartLabels,
                datasets: [{
                    label: 'Doanh thu (triệu đồng)',
                    data: chartValues,
                    backgroundColor: 'rgba(13,110,253,0.7)',
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: true, position: 'top' },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                return context.raw + ' triệu đồng';
                            }
                        }
                    }
                },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });
    </script>
}
