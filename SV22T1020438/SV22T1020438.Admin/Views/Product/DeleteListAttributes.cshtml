@model ProductAttribute
@{
    ViewBag.Title = "Xóa thuộc tính";
}
@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger">
        <i class="bi bi-trash me-1"></i>
        Xóa
    </button>
    <a href="~/Product/Edit/@Model.ProductID#attributes" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa thuộc tính
                </h5>
            </div>
            <div class="card-body">
                <form id="formDelete" method="post" action="~/Product/DeleteAttribute/@Model.ProductID?attributeId=@Model.AttributeID">
                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle me-2"></i>
                        Bạn có chắc chắn muốn xóa thuộc tính này không?
                    </div>
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Tên thuộc tính</dt>
                        <dd class="col-sm-9">@Model.AttributeName</dd>
                        <dt class="col-sm-3">Giá trị</dt>
                        <dd class="col-sm-9">@Model.AttributeValue</dd>
                        <dt class="col-sm-3">Thứ tự</dt>
                        <dd class="col-sm-9">@Model.DisplayOrder</dd>
                    </dl>
                </form>
            </div>
        </div>
    </div>
</div>
