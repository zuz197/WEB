@model List<ProductPhoto>
@{
    Layout = null;
    int productID = ViewBag.ProductID ?? (Model.FirstOrDefault()?.ProductID ?? 0);
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="photos" class="mb-0">
                            <i class="bi bi-images me-2"></i>
                            Thư viện ảnh
                        </h6>
                    </div>
                    <div class="col text-end">
                        @if (productID > 0)
                        {
                            <a class="btn btn-sm btn-primary" href="~/Product/CreatePhoto/@productID">
                                <i class="bi bi-plus-circle me-1"></i>
                                Thêm ảnh
                            </a>
                        }
                        else
                        {
                            <span class="text-muted small">Lưu mặt hàng trước để thêm ảnh</span>
                        }
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:120px">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:120px">Hiển thị</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">Chưa có ảnh</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.OrderBy(x => x.DisplayOrder))
                            {
                                <tr>
                                    <td class="text-center">
                                        <img src="~/images/products/@(string.IsNullOrWhiteSpace(item.Photo) ? "nophoto.png" : item.Photo)"
                                             class="img-thumbnail"
                                             style="max-height:80px;" />
                                    </td>
                                    <td>@item.Description</td>
                                    <td class="text-center">@item.DisplayOrder</td>
                                    <td class="text-center">
                                        @if (item.IsHidden)
                                        {
                                            <span class="badge bg-secondary">Ẩn</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Hiện</span>
                                        }
                                    </td>
                                    <td class="text-center text-nowrap">
                                        <a class="btn btn-sm btn-primary" href="~/Product/EditPhoto/@productID?photoId=@item.PhotoID">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a class="btn btn-sm btn-danger" href="~/Product/DeletePhoto/@productID?photoId=@item.PhotoID">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>