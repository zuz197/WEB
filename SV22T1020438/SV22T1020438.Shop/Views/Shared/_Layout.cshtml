@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - NPT Shop</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <!-- ✅ ICON -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <link href="/css/site.css" rel="stylesheet" />
</head>
<body>
@{
    var customerName = Context.Session.GetString("CustomerName");
    var isLoggedIn = !string.IsNullOrEmpty(customerName);

    // không dùng Session.Clear() để tránh mất captcha & failCount
    if (!(User?.Identity != null && User.Identity.IsAuthenticated))
    {
        // Chỉ reset trạng thái hiển thị
        customerName = null;
        isLoggedIn = false;

        // Nếu cần thì chỉ xoá session login (KHÔNG đụng captcha)
        Context.Session.Remove("CustomerID");
        Context.Session.Remove("CustomerName");
    }

    var path = Context.Request.Path.Value?.ToLower() ?? "";
    var hideFooter = path.Contains("/account/login") || path.Contains("/product/details");
}

<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
    <div class="container">
        <a class="navbar-brand fw-bold" asp-controller="Product" asp-action="Index">
            🛒 NPT Shop
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Product" asp-action="Index">
                        <i class="bi bi-box-seam me-1"></i> Sản phẩm
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Cart" asp-action="Index">
                        <i class="bi bi-cart3 me-1"></i> Giỏ hàng
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Order" asp-action="Index">
                        <i class="bi bi-receipt me-1"></i> Đơn hàng
                    </a>
                </li>

            </ul>

            <ul class="navbar-nav">
                @if (isLoggedIn)
                {
                    <li class="nav-item">
                        <span class="nav-link">
                            <i class="bi bi-person-circle me-1"></i> @customerName
                        </span>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Profile">
                            <i class="bi bi-person-lines-fill me-1"></i> Cá nhân
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="ChangePassword">
                            <i class="bi bi-key me-1"></i> Đổi mật khẩu
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Logout">
                            <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                        </a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Register">
                            <i class="bi bi-person-plus me-1"></i> Đăng ký
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-4">
    @RenderBody()
</div>

@if (!hideFooter)
{
    <footer class="bg-primary text-white text-center py-3 mt-4">
        <div class="container">NPT Shop</div>
    </footer>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>