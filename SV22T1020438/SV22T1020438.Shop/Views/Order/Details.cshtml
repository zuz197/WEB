@model List<SV22T1020438.Shop.Models.OrderDetail>

@{
    ViewBag.Title = "Chi tiết đơn hàng";

    // 👉 lấy status từ controller
    int status = ViewBag.Status != null ? (int)ViewBag.Status : 0;
}

<div class="container mt-4">
    <h3 class="text-primary mb-4">📄 Chi tiết đơn hàng</h3>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-warning text-center">
            Không có dữ liệu.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-bordered table-hover align-middle mb-0">
                    <thead class="table-primary text-center">
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Giá</th>
                            <th>Số lượng</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            decimal total = 0;
                        }

                        @foreach (var item in Model)
                        {
                            var sub = item.SalePrice * item.Quantity;
                            total += sub;

                            <tr>
                                <td>@item.ProductName</td>

                                <td class="text-end">
                                    @item.SalePrice.ToString("N0") đ
                                </td>

                                <td class="text-center">
                                    @item.Quantity
                                </td>

                                <td class="text-end text-danger fw-bold">
                                    @sub.ToString("N0") đ
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="text-end mt-3">
            <h4 class="text-danger">
                Tổng tiền: @total.ToString("N0") đ
            </h4>
        </div>

        <div class="mt-3 d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">
                ← Quay lại
            </a>

            @if (status == 1 || status == 2)
            {
                <form asp-action="Cancel" method="post"
                      onsubmit="return confirm('Bạn có chắc muốn huỷ đơn này?');">
                    <input type="hidden" name="id" value="@ViewBag.OrderID" />
                    <button type="submit" class="btn btn-danger">
                        ❌ Huỷ đơn
                    </button>
                </form>
            }
        </div>
    }
</div>